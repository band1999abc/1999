{
  "framework": null,
  "outputDirectory": ".",
  "functions": {
    "api/afterhours.js":        { "includeFiles": "templates/**" },
    "api/afterhours-diary.js":  { "includeFiles": "templates/**" },
    "api/afterhours-live.js":   { "includeFiles": "templates/**" },
    "api/afterhours-login.js":  { "includeFiles": "templates/**" }
  },
  "rewrites": [
    { "source": "/afterhours/diary",  "destination": "/api/afterhours-diary"  },
    { "source": "/afterhours/live",   "destination": "/api/afterhours-live"   },
    { "source": "/afterhours/login",  "destination": "/api/afterhours-login"  },
    { "source": "/afterhours",        "destination": "/api/afterhours"        }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/templates/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Robots-Tag",  "value": "noindex"  }
      ]
    }
  ]
}
