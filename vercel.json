{
  "framework": null,
  "outputDirectory": ".",
  "functions": {
    "api/afterhours.js": { "includeFiles": "templates/**" }
  },
  "rewrites": [
    { "source": "/afterhours", "destination": "/api/afterhours" }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/templates/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Robots-Tag",  "value": "noindex"  }
      ]
    }
  ]
}
